generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model CouponCounter {
  id        Int      @id
  current   Int      @default(99)
  updatedAt DateTime @updatedAt
}

model Lead {
  id           Int      @id @default(autoincrement())
  name         String
  phone        String
  couponSerial Int      @unique
  couponCode   String   @unique
  consentGiven Boolean
  consentAt    DateTime
  createdAt    DateTime @default(now())
}
